{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "packages/librecode/src/**/*.ts",
      "packages/librecode/src/**/*.tsx",
      "packages/librecode/test/**/*.ts",
      "packages/util/src/**/*.ts",
      "packages/util/test/**/*.ts",
      "packages/plugin/src/**/*.ts",
      "packages/plugin/test/**/*.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 12
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noDoubleEquals": "warn",
        "noImplicitAnyLet": "warn",
        "noControlCharactersInRegex": "warn",
        "useIterableCallbackReturn": "warn",
        "noAsyncPromiseExecutor": "warn",
        "noRedeclare": "warn",
        "noShadowRestrictedNames": "warn",
        "noGlobalAssign": "warn"
      },
      "style": {
        "noNamespace": "warn",
        "noDefaultExport": "warn",
        "useConst": "error"
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "noConstantCondition": "warn"
      },
      "performance": {
        "noDelete": "off"
      },
      "a11y": {
        "noStaticElementInteractions": "off",
        "useKeyWithMouseEvents": "off"
      }
    }
  },
  "formatter": {
    "enabled": false
  }
}
