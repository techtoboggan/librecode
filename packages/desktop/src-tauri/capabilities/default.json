{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "comment": "A05 — opener was permitting `**/*` on any path with `app: true`, giving the frontend full file/program-launch access to the user's machine. Narrow to user-accessible locations that are in-scope for a coding agent: project workspaces under $HOME, common download/temp dirs, and files already running (to re-open the app itself from a tray click).",
      "allow": [
        { "path": "$HOME/**/*" },
        { "path": "$HOME/.*/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" },
        { "path": "$HOME/**/*", "app": true },
        { "path": "$DOWNLOAD/**", "app": true }
      ]
    },
    "deep-link:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-theme",
    "core:webview:allow-set-webview-zoom",
    "core:window:allow-is-focused",
    "core:window:allow-show",
    "core:window:allow-unminimize",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-size",
    "core:window:allow-is-maximized",
    "core:window:allow-toggle-maximize",
    "decorum:allow-show-snap-overlay",
    "shell:default",
    "updater:default",
    "dialog:default",
    "process:default",
    "store:default",
    "window-state:default",
    "os:default",
    "notification:default",
    {
      "identifier": "http:default",
      "comment": "A05 — was `http://*, https://*` which let any compromised frontend JS talk to any host via the Tauri HTTP bridge (bypasses browser CORS). Narrow to: local CLI server on loopback, LibreCode cloud, GitHub (updater + release notes). All LLM provider calls go server-side through the CLI, not through this frontend bridge, so provider hosts are intentionally NOT in the allowlist — if we need one, it's a code change, not an unrestricted HTTP grant.",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://[::1]:*/*" },
        { "url": "https://app.librecode.ai/**" },
        { "url": "https://librecode.ai/**" },
        { "url": "https://github.com/techtoboggan/**" },
        { "url": "https://api.github.com/repos/techtoboggan/**" },
        { "url": "https://raw.githubusercontent.com/techtoboggan/**" },
        { "url": "https://objects.githubusercontent.com/**" }
      ]
    },
    "clipboard-manager:allow-read-image"
  ]
}
