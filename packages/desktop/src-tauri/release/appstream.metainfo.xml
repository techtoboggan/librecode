<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.librecode.desktop</id>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <name>LibreCode</name>
  <summary>AI-powered development tool</summary>

  <developer id="com.techtoboggan">
    <name>techtoboggan</name>
  </developer>

  <description>
    <p>
      LibreCode is an AI-powered development tool for the terminal and desktop.
      It connects to LLM providers (Anthropic, OpenAI, Google, local models, and more),
      understands your codebase, and helps you build software faster.
    </p>
    <p>
      Features include multi-provider support (20+), MCP server integration,
      session branching, permission management with audit logging, and proper
      Linux packaging via COPR, AUR, and Nix.
    </p>
  </description>

  <launchable type="desktop-id">com.librecode.desktop.desktop</launchable>

  <content_rating type="oars-1.1" />

  <categories>
    <category>Development</category>
    <category>IDE</category>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>ai</keyword>
    <keyword>coding</keyword>
    <keyword>agent</keyword>
    <keyword>llm</keyword>
    <keyword>terminal</keyword>
    <keyword>development</keyword>
  </keywords>

  <url type="bugtracker">https://github.com/techtoboggan/librecode/issues</url>
  <url type="homepage">https://librecode.io</url>
  <url type="vcs-browser">https://github.com/techtoboggan/librecode</url>
  <url type="donation">https://github.com/sponsors/techtoboggan</url>

  <releases>
    <release version="0.1.0" date="2026-04-11">
      <description>
        <p>v0.1.0 — first stable release. Local-first architecture with LiteLLM, Ollama,
        Bedrock, and Azure as built-in providers. Community plugin ecosystem via npm.</p>
      </description>
      <url type="details">https://github.com/techtoboggan/librecode/releases/tag/v0.1.0</url>
    </release>
    <release version="0.0.1" date="2026-04-09">
      <description>
        <p>First LibreCode release.</p>
      </description>
      <url type="details">https://github.com/techtoboggan/librecode/releases/tag/v0.0.1</url>
    </release>
  </releases>

  <bundle type="flatpak">com.librecode.desktop</bundle>
</component>
