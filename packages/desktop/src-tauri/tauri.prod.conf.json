{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LibreCode",
  "identifier": "com.librecode.desktop",
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost http://localhost:* https://app.librecode.ai https://api.anthropic.com https://api.openai.com https://openrouter.ai https://*.githubusercontent.com https://github.com; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; frame-src 'self'; worker-src 'self' blob:; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/prod/32x32.png",
      "icons/prod/128x128.png",
      "icons/prod/128x128@2x.png",
      "icons/prod/icon.icns",
      "icons/prod/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/prod/icon.ico"
      }
    },
    "macOS": {
      "signingIdentity": null,
      "dmg": {
        "background": null,
        "windowPosition": { "x": 400, "y": 100 },
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/com.librecode.desktop.metainfo.xml": "release/appstream.metainfo.xml"
        }
      },
      "rpm": {
        "compression": {
          "type": "none"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwMDM5Nzg5OUMzOUExMDQKUldRRW9UbWNpWmNEOENYT01CV0lhOXR1UFhpaXJsK1Z3aU9lZnNtNzE0TDROWVMwVW9XQnFOelkK",
      "endpoints": ["https://github.com/techtoboggan/librecode/releases/latest/download/latest.json"]
    }
  }
}
