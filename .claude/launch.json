{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "librecode-web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--cwd", "packages/app", "dev"],
      "port": 3000
    },
    {
      "name": "librecode-io",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "3100", "--directory", "sites/io"],
      "port": 3100
    },
    {
      "name": "librecode-app",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "3101", "--directory", "sites/app"],
      "port": 3101
    },
    {
      "name": "brand-preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "3102", "--directory", "assets/brand"],
      "port": 3102
    }
  ]
}
